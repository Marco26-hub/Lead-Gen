# ============================================================
# Social Web Automation — environment variables
# Copy to .env (root) and fill real values. Never commit secrets;
# .env / .env.local are gitignored, this .env.example is the template.
# Both the Next app AND the orchestrator CLI read this root .env.
# ============================================================

# ============================================================
# DATABASE — Supabase Postgres (UNICO database)
# ============================================================
# Used by Drizzle (Better Auth + clients/appointments in schema `agency`)
# and by drizzle-kit migrations. Supabase → Project Settings → Database →
# Connection string. Use the DIRECT/session string for migrations; the
# transaction pooler (port 6543) is fine for app runtime on Vercel.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require"

# Supabase client (lead-gen tables in `public` via supabase-js + Storage).
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""          # server-only, bypassa RLS
SUPABASE_ANON_KEY=""
SUPABASE_STORAGE_BUCKET="lead-photos"

# ============================================================
# AUTH — Better Auth (login unico per /admin e /app)
# ============================================================
BETTER_AUTH_SECRET="replace-with-a-long-random-string"   # openssl rand -base64 32
BETTER_AUTH_URL="https://socialwebautomation.com"

# Primo admin (letto solo da `pnpm db:seed`)
SEED_ADMIN_EMAIL="you@example.com"
SEED_ADMIN_PASSWORD="choose-a-strong-password"
SEED_ADMIN_NAME="Your Name"

# ============================================================
# DOMINIO PUBBLICO — link demo/OG/unsubscribe generati dal lead-gen
# ============================================================
PUBLIC_BASE_URL="https://socialwebautomation.com"

# ============================================================
# Contact form (Resend)
# ============================================================
CONTACT_TO_EMAIL=""
CONTACT_FROM_EMAIL="Social Web Automation <onboarding@resend.dev>"

# ============================================================
# LEAD-GEN — integrazioni (app + orchestrator)
# ============================================================
# Apify (scraping Google Maps)
APIFY_TOKEN=""
APIFY_WEBHOOK_SECRET=""

# OpenRouter (generazione pagine demo via LLM)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="https://socialwebautomation.com"
OPENROUTER_APP_NAME="Social Web Automation"

# Resend (email outreach + booking)
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
RESEND_WEBHOOK_SECRET=""

# Twilio / WhatsApp
WHATSAPP_PROVIDER=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
WHATSAPP_FROM=""
OUTREACH_TEST_WHATSAPP=""

# Stripe (billing/attivazioni)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Outreach / sales metadata
OUTREACH_TEST_RECIPIENT=""
OUTREACH_DAILY_CAP="20"
SPAM_RATE_THRESHOLD="0.003"
SENDER_NAME=""
SENDER_ADDRESS=""
SENDER_VAT=""
SALES_CALENDLY_URL=""
SALES_WHATSAPP=""
SALES_EMAIL="info@socialwebautomation.com"
